NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-public-key
NEXT_PUBLIC_APP_MODE=production
NEXT_PUBLIC_ENABLE_PWA_DEV=false

# Optional local visual-testing accounts. Never enable these in production.
NEXT_PUBLIC_ENABLE_TEST_LOGIN=false
NEXT_PUBLIC_TEST_ADMIN_EMAIL=
NEXT_PUBLIC_TEST_ADMIN_PASSWORD=
NEXT_PUBLIC_TEST_RESEARCHER_EMAIL=
NEXT_PUBLIC_TEST_RESEARCHER_PASSWORD=
NEXT_PUBLIC_TEST_SUPERVISOR_EMAIL=
NEXT_PUBLIC_TEST_SUPERVISOR_PASSWORD=
NEXT_PUBLIC_TEST_REVIEWER_EMAIL=
NEXT_PUBLIC_TEST_REVIEWER_PASSWORD=
NEXT_PUBLIC_TEST_ENUMERATOR_EMAIL=
NEXT_PUBLIC_TEST_ENUMERATOR_PASSWORD=
